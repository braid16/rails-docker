<div class="pull-right">
  <%= link_to("Add a job", new_job_path, :class => "btn btn-default" ) %>
</div>

<table class="table table-bordered">
  <% @jobs.each do |job| %>
  <tr>
    <td>
       <%= link_to(job.title, job_path(job)) %>
    </td>
    <td>
       <%= link_to("Edit", edit_job_paht(job)) %> |
       <%= link_to("Destroy", job_paht(job), :method => :delete, :data => { :confirm => "Are you sure? })
    </td>

    <td>
       <%= job.created_at %>
    </td>
  </tr>
  <% end %>
</table>
